		"devdoc": {
			"custom:version": "v1.6",
			"details": "Uses BattleLibrary for deterministic combat resolution. Gas-optimized per TЗ Variant 1:      - No storage of full BattleEvent arrays (only summary + lastBattleId).      - All detailed events emitted via logs (cheap for frontend replay via getLogs).      - AI team generated on-chain deterministically.",
			"kind": "dev",
			"methods": {
				"buyFromShop(uint256)": {
					"details": "This fixes previous fake relic IDs. Real mint happens here."
				},
				"buyUnit()": {
					"details": "Uses block.prevrandao for better randomness than timestamp only."
				},
				"constructor": {
					"params": {
						"_relic": "Address of deployed StarForgeRelic",
						"_unitNFT": "Address of deployed StarForgeUnitNFT"
					}
				},
				"startMatch(uint256[],uint256[])": {
					"details": "AI team is generated deterministically here (critical fix from previous broken version).      Gas optimization per TЗ: only summary stored + events emitted (no full BattleEvent[] storage).",
					"params": {
						"equipped": "Array of relic IDs to apply this match (can be empty)",
						"team": "Array of player's unit token IDs"
					}
				}
			},
			"title": "StarForgeGame",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"buyFromShop(uint256)": {
					"notice": "Buys item from shop slot. If relic — mints real ERC-1155 via Relic contract."
				},
				"buyUnit()": {
					"notice": "Buys a new random unit for 0.01 ETH. Mints ERC-721 via UnitNFT."
				},
				"constructor": {
					"notice": "Initializes the game with existing NFT and Relic contracts."
				},
				"createProfile()": {
					"notice": "Creates a new player profile. Can be called only once per address."
				},
				"rerollShop()": {
					"notice": "Rerolls the 3-item shop for 0.005 ETH."
				},
				"startMatch(uint256[],uint256[])": {
					"notice": "Starts an on-chain auto-battle. Team size 4-8."
				}
			},
			"notice": "Main game contract for Somnia StarForge — fully on-chain Auto-Battler (TFT-like).",
			"version": 1
		}
	},
